{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "regexManagers": [
    {
      "managerFilePatterns": [
        "^roles/github/vars/main\\.yml$"
      ],
      "matchStrings": [
        "repo:\\s+[\"']?(?<depName>[\\w\\-\\./]+)[\"']?\\n\\s+version:\\s+[\"']?(?<currentValue>[\\d\\.]+)[\"']?"
      ],
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "github-releases"
      ],
      "extractVersion": "^v?(?<version>.*)$"
    }
  ]
}